# LLM Selection: OMLX, OLLAMA, GROQ, OPENROUTER
LLM_PROVIDER=OMLX

# oMLX OpenAI-compatible endpoint.
# Inside Docker Compose, use http://host.docker.internal:1234/v1.
OMLX_BASE_URL=http://127.0.0.1:1234/v1
OMLX_MODEL=Gemma4-MTP-26B-BF16
# Optional: leave unset to read Morning Dispatch env or ~/.omlx/settings.json.
OMLX_API_KEY=

# Mac Studio tuning
EMBEDDING_DEVICE=auto
EMBEDDING_BATCH_SIZE=64
INGEST_BATCH_SIZE=512
RETRIEVER_K=12
RETRIEVER_FETCH_K=80

# Groq API Key
GROQ_API_KEY=your_groq_api_key_here

# OpenRouter API Key
OPENROUTER_API_KEY=your_openrouter_api_key_here

# Ollama Base URL (default is http://localhost:11434)
OLLAMA_BASE_URL=http://localhost:11434

# Data Path
DATA_PATH=./data
DB_PATH=./chroma_db
